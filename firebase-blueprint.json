{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores player stats and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "level": { "type": "integer", "description": "Player's current level." },
        "rp": { "type": "integer", "description": "Player's current RP." },
        "rpToNext": { "type": "integer", "description": "RP required for the next level." },
        "cash": { "type": "integer", "description": "Player's current cash." },
        "bank": { "type": "integer", "description": "Player's current bank balance." },
        "title": { "type": "string", "description": "Player's current title (e.g., Underworld Kingpin)." },
        "alias": { "type": "string", "description": "Player's current alias (e.g., The Kingpin)." },
        "lastActive": { "type": "string", "format": "date-time", "description": "Timestamp of the user's last activity." },
        "status": { "type": "string", "enum": ["Online", "In Mission", "Offline"], "description": "Current online status." }
      },
      "required": ["uid", "displayName", "level", "rp", "cash", "bank"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the global chat.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The UID of the sender." },
        "authorName": { "type": "string", "description": "The name of the sender." },
        "text": { "type": "string", "description": "The content of the message." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["uid", "authorName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles and stats."
    },
    "/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Global chat messages."
    }
  }
}
