rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches request.auth.uid)
    // Fields:
    //   - uid: string (required, immutable)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - level: number (required, min: 1)
    //   - rp: number (required, min: 0)
    //   - rpToNext: number (required, min: 0)
    //   - cash: number (required, min: 0)
    //   - bank: number (required, min: 0)
    //   - title: string (optional)
    //   - alias: string (optional)
    //   - lastActive: string (optional, ISO 8601)
    //   - status: string (optional, enum: ["Online", "In Mission", "Offline"])
    //
    // Collection: chat
    // Document ID: {messageId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - authorName: string (required)
    //   - text: string (required, max: 500)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "tusharsingh977579@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'level', 'rp', 'cash', 'bank']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.level is int && data.level >= 1 &&
             data.rp is int && data.rp >= 0 &&
             data.cash is int && data.cash >= 0 &&
             data.bank is int && data.bank >= 0;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['uid', 'authorName', 'text', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read any profile to see the session list
      allow read: if isAuthenticated();
      
      // Users can only create/update their own profile
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid;
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    match /chat/{messageId} {
      // Anyone authenticated can read chat
      allow read: if isAuthenticated();
      
      // Anyone authenticated can post a valid message
      allow create: if isAuthenticated() && isValidChatMessage(request.resource.data);
      
      // Chat messages are immutable
      allow update: if false;
      
      // Only admins or the author can delete messages
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.uid);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
